{
  "name": "aura-engine",
  "version": "0.1.0",
  "description": "Responsive ambience engine powered by AI. A real-time sensory layer for text, voice and agentic interfaces.",
  "type": "module",
  "private": false,
  "author": "Álvaro Alencar",
  "license": "MIT",
  "scripts": {
    "dev": "vite examples/browser-demo --host 0.0.0.0",
    "server": "tsx packages/server/src/server.ts",
    "build": "tsc --noEmit && vite build examples/browser-demo --outDir ../../dist/browser-demo",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "start": "node dist/server/server.js"
  },
  "keywords": [
    "ai",
    "ambience",
    "audio",
    "soundscape",
    "web-audio",
    "agentic-interfaces",
    "responsive-ui",
    "ambient-computing",
    "ai-interface"
  ],
  "devDependencies": {
    "@types/node": "latest",
    "@vitejs/plugin-basic-ssl": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
